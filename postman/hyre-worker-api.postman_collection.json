  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const requestUrl = pm.request.url.toString();",
          "const authRole = (pm.environment.get(\"authRole\") || pm.collectionVariables.get(\"authRole\") || \"user\").trim();",
          "const webOrigin = pm.environment.get(\"webOrigin\") || pm.collectionVariables.get(\"webOrigin\") || \"http://localhost:5173\";",
          "const fleetOwnerReferer = pm.environment.get(\"fleetOwnerReferer\") || pm.collectionVariables.get(\"fleetOwnerReferer\") || `${webOrigin}/fleet-owner/login`;",
          "const userReferer = pm.environment.get(\"userReferer\") || pm.collectionVariables.get(\"userReferer\") || `${webOrigin}/login`;",
          "",
          "if (!requestUrl.includes(\"/api/auth/\")) {",
          "  return;",
          "}",
          "",
          "pm.request.headers.upsert({ key: \"Origin\", value: webOrigin });",
          "pm.request.headers.upsert({ key: \"Referer\", value: authRole === \"fleetOwner\" ? fleetOwnerReferer : userReferer });",
          "pm.request.headers.remove(\"x-client-type\");",
          "",
          "const roleValidatedPaths = [",
          "  \"/api/auth/email-otp/send-verification-otp\",",
          "  \"/api/auth/email-otp/verify-email\",",
          "  \"/api/auth/sign-in/email-otp\"",
          "];",
          "",
          "const shouldInjectRole = roleValidatedPaths.some((path) => requestUrl.includes(path));",
          "if (!shouldInjectRole || !pm.request.body || pm.request.body.mode !== \"raw\") {",
          "  return;",
          "}",
          "",
          "try {",
          "  const raw = pm.request.body.raw || \"{}\";",
          "  const payload = JSON.parse(raw);",
          "  payload.role = authRole;",
          "  pm.request.body.update(JSON.stringify(payload, null, 2));",
          "} catch (error) {",
          "  console.log(\"Skipping role injection: non-JSON auth body\", error);",
          "}"
        ]
      }
    }
  ],
