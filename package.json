{
  "name": "hyre-worker",
  "version": "1.0.0",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "npx prisma generate && nest build",
    "format": "biome format --write src",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "check": "biome check src",
    "check:fix": "biome check --write src",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:coverage:ci": "vitest --coverage --run && npx nyc report --reporter=lcov --temp-dir=coverage --report-dir=coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "npx dotenv -e .env.e2e -o -- vitest run --config vitest.e2e.config.mjs",
    "db:generate": "prisma generate",
    "deploy": "pnpm run build && pnpm run db:generate",
    "prepare": "husky",
    "pretype-check": "prisma generate",
    "type-check": "pnpm run pretype-check && tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@better-auth/prisma-adapter": "^1.5.3",
    "@bull-board/api": "^6.14.0",
    "@bull-board/express": "^6.14.0",
    "@bull-board/nestjs": "^6.14.0",
    "@date-fns/utc": "^2.1.1",
    "@langchain/anthropic": "^1.3.21",
    "@langchain/core": "^1.1.29",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/openai": "^1.2.11",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.17",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation-pino": "^0.57.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-email/components": "^0.3.3",
    "@react-email/render": "^1.2.1",
    "axios": "^1.15.0",
    "better-auth": "^1.4.18",
    "bullmq": "^5.63.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "nestjs-pino": "^4.5.0",
    "openai": "^6.22.0",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-opentelemetry-transport": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.1.14",
    "resend": "^6.5.2",
    "rxjs": "^7.8.2",
    "twilio": "^5.11.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "@commitlint/cli": "^20.4.0",
    "@commitlint/config-conventional": "^20.4.0",
    "@flydotio/dockerfile": "^0.7.10",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^11.1.17",
    "@swc/core": "^1.13.5",
    "@testcontainers/postgresql": "^11.8.0",
    "@testcontainers/redis": "^11.8.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.13",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.5.0",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "unplugin-swc": "^1.5.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": "5.0.5",
      "body-parser": "2.2.1",
      "effect": "3.20.0",
      "fast-xml-parser": "5.5.7",
      "flatted": "3.4.2",
      "kysely": "0.28.14",
      "lodash": "4.17.23",
      "minimatch": "10.2.3",
      "multer": "2.1.1",
      "path-to-regexp": "8.4.0",
      "picomatch": "4.0.4",
      "qs": "6.14.2",
      "rollup": "4.59.0",
      "defu": "6.1.5",
      "vite": "7.3.2",
      "protobufjs": "7.5.5"
    },
    "ignoredBuiltDependencies": [
      "@nestjs/core",
      "@swc/core",
      "cpu-features",
      "esbuild",
      "msgpackr-extract",
      "protobufjs",
      "ssh2"
    ],
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  }
}
